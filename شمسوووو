@bot.message_handler(func=lambda m: m.text and len(m.text) >= 9 and m.text[0] in ['0', '7'])
def handle_phone(message):
    
    chat_id = message.chat.id
    
    if safe_get_state(chat_id) != 'waiting_phone':
        return
    
    if not is_subscribed(chat_id):
        bot.send_message(chat_id, "🚫 يجب الاشتراك في القنوات!", reply_markup=get_subscribe_keyboard())
        safe_delete_user(chat_id)
        return
    
    phone = format_num(message.text)
    safe_save_user_data(chat_id, 'phone', phone)
    
    status_msg = bot.send_message(chat_id, "⏳ جاري إرسال رمز التحقق...")
    
    resp = request_otp(phone)
    
    if resp and resp.status_code in [200, 201]:
        safe_set_state(chat_id, 'waiting_otp')
        try:
            bot.edit_message_text(
                "✅ تم إرسال الرمز بنجاح!\n\n📨 أدخل رمز التحقق (6 أرقام):",
                chat_id,
                status_msg.message_id
            )
        except:
            bot.send_message(chat_id, "✅ تم إرسال الرمز!\n📨 أدخل رمز التحقق (6 أرقام):")
    else:
        try:
            bot.edit_message_text(
                "❌ فشل إرسال الرمز.\nتأكد من الرقم وحاول مجدداً.",
                chat_id,
                status_msg.message_id,
                reply_markup=get_main_keyboard()
            )
        except:
            bot.send_message(chat_id, "❌ فشل إرسال الرمز.", reply_markup=get_main_keyboard())
        safe_delete_user(chat_id)

@bot.message_handler(func=lambda m: m.text and m.text.isdigit() and len(m.text) == 6)
def handle_otp(message):
    
    chat_id = message.chat.id
    
    if safe_get_state(chat_id) != 'waiting_otp':
        return
    
    if not is_subscribed(chat_id):
        bot.send_message(chat_id, "🚫 يجب الاشتراك في القنوات!", reply_markup=get_subscribe_keyboard())
        safe_delete_user(chat_id)
        return
    
    otp = message.text
    phone = safe_get_user_data(chat_id, 'phone')
    
    if not phone:
        bot.send_message(chat_id, "❌ حدث خطأ، أعد المحاولة من البداية.", reply_markup=get_main_keyboard())
        safe_delete_user(chat_id)
        return
    
    status_msg = bot.send_message(chat_id, "🔄 جاري التفعيل...")
    
    token = login_with_otp(phone, otp)
    
    if not token:
        try:
            bot.edit_message_text(
                "❌ رمز التحقق غير صحيح أو انتهت صلاحيته.",
                chat_id,
                status_msg.message_id,
                reply_markup=get_main_keyboard()
            )
        except:
            bot.send_message(chat_id, "❌ رمز التحقق غير صحيح.", reply_markup=get_main_keyboard())
        safe_delete_user(chat_id)
        return
    
    max_attempts = 30
    success = False
    
    for attempt in range(1, max_attempts + 1):
        try:
            target = generate_random_djezzy_no()
            target_f = format_num(target)
                                   
            if send_invitation(token, phone, target_f):
               
                request_otp(target_f)
                time.sleep(1.5)
                               
                if activate_reward(token, phone):
                    success = True
                    
                    success_msg = f"""
<b>✅ تم التفعيل بنجاح! 🎉</b>

تم تفعيل 1GB على رقمك

<b>شكراً لاستخدام البوت</b>
📢 {CHANNELS[0]}
"""
                    try:
                        bot.edit_message_text(
                            success_msg,
                            chat_id,
                            status_msg.message_id,
                            reply_markup=get_final_keyboard()
                        )
                    except:
                        bot.send_message(chat_id, success_msg, reply_markup=get_final_keyboard())
                    break
            
            time.sleep(1)
            
        except Exception as e:
            logging.error(f"خطأ في المحاولة {attempt}: {e}")
            continue
    
    if not success:
        fail_msg = f"""
<b>❌ لم نتمكن من التفعيل حالياً</b>

حاول مرة أخرى لاحقاً
قد يكون الرقم غير مؤهل حالياً

📢 {CHANNELS[0]}
"""
        try:
            bot.edit_message_text(
                fail_msg,
                chat_id,
                status_msg.message_id,
                reply_markup=get_final_keyboard()
            )
        except:
            bot.send_message(chat_id, fail_msg, reply_markup=get_final_keyboard())
    
    
    safe_delete_user(chat_id)

