def safe_save_user_data(chat_id, key, value):
   
    with data_lock:
        if chat_id not in user_sessions:
            user_sessions[chat_id] = {}
        user_sessions[chat_id][key] = value

def safe_get_user_data(chat_id, key, default=None):
    with data_lock:
        if chat_id in user_sessions:
            return user_sessions[chat_id].get(key, default)
        return default

def safe_set_state(chat_id, state):
   
    with data_lock:
        user_states[chat_id] = state

def safe_get_state(chat_id):
    with data_lock:
        return user_states.get(chat_id)

def safe_delete_user(chat_id):
    with data_lock:
        if chat_id in user_sessions:
            del user_sessions[chat_id]
        if chat_id in user_states:
            del user_states[chat_id]

def format_num(phone):
    
    try:
        phone = str(phone).strip()
        phone = ''.join(filter(str.isdigit, phone))
        if phone.startswith('0'):
            return "213" + phone[1:]
        elif not phone.startswith('213'):
            return "213" + phone
        return phone
    except:
        return phone

