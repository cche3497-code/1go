def run_bot():
   
    restart_count = 0
    
    while True:
        try:
            print("=" * 60)
            print("🤖 بوت تفعيل 1GB من جيزي يعمل الآن")
            print(f"📢 القنوات: {', '.join(CHANNELS)}")
            print(f"🔄 عدد مرات إعادة التشغيل: {restart_count}")
            print("=" * 60)
                       
            with data_lock:
                if len(user_sessions) > 500:
                    user_sessions.clear()
                    user_states.clear()
            
            restart_count += 1
            bot.infinity_polling(timeout=20, long_polling_timeout=20, skip_pending=True)
            
        except Exception as e:
            logging.error(f"خطأ في تشغيل البوت: {e}")
            print(f"⚠️ خطأ: {e} - إعادة التشغيل خلال 3 ثوان...")
            time.sleep(3)
            continue

if __name__ == '__main__':
    try:
        run_bot()
    except KeyboardInterrupt:
        print("\n👋 تم إيقاف البوت يدوياً")
    except Exception as e:
        print(f"❌ خطأ غير متوقع: {e}")
        time.sleep(3)
        os.system(f"python {__file__}") 
